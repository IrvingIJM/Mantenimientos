@model Mantenimientos.Models.ViewModels.ObservacionVM

@{
    ViewData["Title"] = "Editar Observación";

    string FormatInput(DateTime? fecha) =>
        fecha.HasValue && fecha.Value > new DateTime(1900, 1, 1)
            ? fecha.Value.ToString("yyyy-MM-dd")
            : string.Empty;

    string FormatDisplay(DateTime? fecha) =>
        fecha.HasValue && fecha.Value > new DateTime(1900, 1, 1)
            ? fecha.Value.ToString("dd/MM/yyyy")
            : "—";
}

<div class="container py-4" style="max-width:860px;">

    <!-- Encabezado -->
    <div class="d-flex align-items-center mb-4 gap-3">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-circle p-2">
            <i class="bi bi-arrow-left"></i>
        </a>
    </div>

    <form asp-action="Observacion" method="post" id="formObservacion" novalidate>
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ID" />
        <input type="hidden" asp-for="CLV_SUC" />

        <!-- Datos de la Sucursal -->
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header py-3 d-flex align-items-center gap-2"
                 style="background:linear-gradient(135deg,#1D3557 0%,#457B9D 100%); color:#fff;">
                <i class="bi bi-building me-1"></i>
                <strong>Sucursal</strong>
                <span class="badge bg-light text-dark ms-2 fw-normal">Solo lectura</span>
            </div>
            <div class="card-body">
                <div class="row g-4">
                    <div class="col-12 col-md-4">
                        <label class="form-label fw-semibold text-muted small text-uppercase">Ruta</label>
                        <div class="form-control-plaintext fw-bold fs-5 text-primary ps-0">
                            <i class="bi bi-signpost me-1"></i> @Model.RUTA
                        </div>
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label fw-semibold text-muted small text-uppercase">Región</label>
                        <div class="form-control-plaintext fw-semibold ps-0 text-dark">
                            <i class="bi bi-geo me-1 text-secondary"></i> @Model.REGION
                        </div>
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label fw-semibold text-muted small text-uppercase">Clave</label>
                        <div class="form-control-plaintext text-muted ps-0">
                            <code>@Model.CLV_SUC</code>
                        </div>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold text-muted small text-uppercase">Nombre de Sucursal</label>
                        <div class="form-control-plaintext fw-bold text-dark ps-0 fs-5">
                            <i class="bi bi-shop me-1 text-primary"></i> @Model.NOMBRE_SUCURSAL
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── Tarjeta: Fechas Estimadas (editables) ────────────────────── -->
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header py-3 d-flex align-items-center gap-2"
                 style="background:#e8f0fe; border-left:4px solid #1D3557;">
                <i class="bi bi-calendar-event text-primary me-1"></i>
                <strong class="text-primary">Fechas Estimadas</strong>
            </div>
            <div class="card-body">
                <div class="row g-4">
                    <div class="col-12 col-md-6">
                        <label asp-for="FECHA_INI_ES" class="form-label fw-semibold">
                            Fecha Inicio Estimada
                        </label>
                        <div class="input-group">
                            <span class="input-group-text bg-light">
                                <i class="bi bi-calendar-plus text-primary"></i>
                            </span>
                            <input name="FECHA_INI_ES"
                                   type="date"
                                   class="form-control"
                                   id="inputFechaIniEst"
                                   value="@FormatInput(Model.FECHA_INI_ES)"
                                   onchange="calcularDesfase()" />
                        </div>
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="FECHA_FIN_ES" class="form-label fw-semibold">
                            Fecha Fin Estimada
                        </label>
                        <div class="input-group">
                            <span class="input-group-text bg-light">
                                <i class="bi bi-calendar-minus text-primary"></i>
                            </span>
                            <input name="FECHA_FIN_ES"
                                   type="date"
                                   class="form-control"
                                   id="inputFechaFinEst"
                                   value="@FormatInput(Model.FECHA_FIN_ES)"
                                   onchange="calcularDesfase()" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── Tarjeta: Fechas Reales (solo lectura — vienen de DBICET) ─── -->
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header py-3 d-flex align-items-center gap-2"
                 style="background:#e8f5e9; border-left:4px solid #2e7d32;">
                <i class="bi bi-calendar-check text-success me-1"></i>
                <strong class="text-success">Fechas Reales</strong>
                <span class="badge bg-light text-dark ms-2 fw-normal">Solo lectura · fuente: DBICET</span>
            </div>
            <div class="card-body">
                <div class="row g-4">

                    <!-- Fecha inicio real -->
                    <div class="col-12 col-md-6">
                        <label class="form-label fw-semibold text-muted small text-uppercase">
                            Fecha Inicio Real
                        </label>
                        <div class="input-group">
                            <span class="input-group-text bg-success-subtle">
                                <i class="bi bi-play-circle text-success"></i>
                            </span>
                            <input type="text"
                                   class="form-control bg-light text-muted fst-italic"
                                   value="@FormatDisplay(Model.FECHA_INI_RE)"
                                   readonly
                                   id="displayFechaIniReal"
                                   tabindex="-1" />
                            <!-- Campo oculto con valor ISO para calcularDesfase() -->
                            <input type="hidden" id="valorFechaIniReal"
                                   value="@FormatInput(Model.FECHA_INI_RE)" />
                        </div>
                        <small class="text-muted">
                            <i class="bi bi-lock me-1"></i>Actualizado automáticamente desde DBICET
                        </small>
                    </div>

                    <!-- Fecha fin real -->
                    <div class="col-12 col-md-6">
                        <label class="form-label fw-semibold text-muted small text-uppercase">
                            Fecha Fin Real
                        </label>
                        <div class="input-group">
                            <span class="input-group-text bg-success-subtle">
                                <i class="bi bi-stop-circle text-success"></i>
                            </span>
                            <input type="text"
                                   class="form-control bg-light text-muted fst-italic"
                                   value="@FormatDisplay(Model.FECHA_FIN_RE)"
                                   readonly
                                   tabindex="-1" />
                            <input type="hidden" id="valorFechaFinReal"
                                   value="@FormatInput(Model.FECHA_FIN_RE)" />
                        </div>
                        <small class="text-muted">
                            <i class="bi bi-lock me-1"></i>Actualizado automáticamente desde DBICET
                        </small>
                    </div>

                </div>

                <!-- ── Panel de días de atraso / adelanto ──────────────── -->
                @{
                    bool tieneIniEst = Model.FECHA_INI_ES.HasValue && Model.FECHA_INI_ES.Value > new DateTime(1900, 1, 1);
                    bool tieneIniReal = Model.FECHA_INI_RE.HasValue;
                    bool tieneFinReal = Model.FECHA_FIN_RE.HasValue;
                    int? dias = Model.DIAS_ATRASO;
                }

                @if (tieneIniEst && tieneIniReal)
                {
                    string panelClass, icono, etiqueta;

                    if (!tieneFinReal)
                    {
                        panelClass = "panel-en-proceso";
                        icono = "bi-hourglass-split text-warning";
                        etiqueta = "En proceso";
                    }
                    else if (dias > 0)
                    {
                        panelClass = "panel-atraso";
                        icono = "bi-exclamation-triangle text-danger";
                        etiqueta = $"{dias} día{(dias == 1 ? "" : "s")} de ATRASO";
                    }
                    else if (dias < 0)
                    {
                        panelClass = "panel-adelanto";
                        icono = "bi-check-circle text-primary";
                        etiqueta = $"{Math.Abs(dias ?? 0)} día{(Math.Abs(dias ?? 0) == 1 ? "" : "s")} ADELANTADO";
                    }
                    else
                    {
                        panelClass = "panel-ok";
                        icono = "bi-check2-all text-success";
                        etiqueta = "EN TIEMPO";
                    }

                    <div class="mt-4 p-3 rounded-3 d-flex align-items-center gap-3 @panelClass">
                        <i class="bi @icono fs-2"></i>
                        <div>
                            <div class="fw-bold fs-5" id="textoDesfase">@etiqueta</div>
                            <small class="text-muted">
                                Comparando fecha estimada vs fecha real de inicio
                            </small>
                        </div>
                    </div>
                }
                else if (tieneIniEst && !tieneIniReal)
                {
                    <div class="mt-4 p-3 rounded-3 d-flex align-items-center gap-3 panel-sin-inicio">
                        <i class="bi bi-clock text-secondary fs-2"></i>
                        <div>
                            <div class="fw-bold fs-5">No iniciado</div>
                            <small class="text-muted">Aún no existe fecha real registrada en DBICET</small>
                        </div>
                    </div>
                }
                else if (!tieneIniEst)
                {
                    <div class="mt-4 p-3 rounded-3 d-flex align-items-center gap-3 panel-sin-programar">
                        <i class="bi bi-calendar-x text-secondary fs-2"></i>
                        <div>
                            <div class="fw-bold fs-5">Sin programar</div>
                            <small class="text-muted">Agrega una fecha estimada para ver el desfase</small>
                        </div>
                    </div>
                }

                <!-- Panel dinámico (se actualiza al cambiar fechas estimadas) -->
                <div id="panelDesfaseDinamico" class="mt-3 p-3 rounded-3 d-none d-flex align-items-center gap-3">
                    <i class="bi fs-2" id="iconoDesfaseDinamico"></i>
                    <div>
                        <div class="fw-bold fs-5" id="textoDesfaseDinamico">—</div>
                        <small class="text-muted">Vista previa al guardar</small>
                    </div>
                </div>

            </div>
        </div>

        <!-- ── Tarjeta: Observaciones (máx. 200 palabras) ───────────────── -->
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header py-3 bg-white border-bottom d-flex align-items-center gap-2">
                <i class="bi bi-chat-square-text text-primary me-1"></i>
                <strong>Observaciones</strong>
            </div>
            <div class="card-body">
                <label asp-for="OBSERVACIONES" class="form-label fw-semibold">
                    Detalle del mantenimiento
                    <span class="text-muted fw-normal">(máximo 200 palabras)</span>
                </label>
                <textarea name="OBSERVACIONES"
                          class="form-control"
                          rows="5"
                          id="txtObservaciones"
                          placeholder="Describe el estado del mantenimiento...">@Model.OBSERVACIONES</textarea>

                <!-- Barra de progreso y contador -->
                <div class="d-flex justify-content-between align-items-center mt-2">
                    <div class="progress flex-grow-1 me-3" style="height:6px;">
                        <div id="barraProgreso"
                             class="progress-bar"
                             role="progressbar"
                             style="width:0%; background-color:#1D3557;"
                             aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">
                        </div>
                    </div>
                    <small id="contadorPalabras" class="text-muted fw-semibold">0 / 200 palabras</small>
                </div>
                <div id="alertaPalabras" class="mt-2 d-none">
                    <small class="text-danger fw-semibold">
                        <i class="bi bi-exclamation-triangle me-1"></i>
                        Límite de 200 palabras alcanzado.
                    </small>
                </div>
            </div>
        </div>

        <!-- ── Botones de acción ─────────────────────────────────────────── -->
        <div class="d-flex gap-3 justify-content-end pt-2">
            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                <i class="bi bi-x-circle me-1"></i>Cancelar
            </a>
            <button type="submit" class="btn btn-primary px-5 shadow-sm"
                    style="background-color:#1D3557; border-color:#1D3557;">
                <i class="bi bi-check-circle me-2"></i>Actualizar Registro
            </button>
        </div>
    </form>
</div>

<!-- ── Estilos del panel de desfase ─────────────────────────────────────── -->
<style>
    .panel-atraso {
        background: #fff5f5;
        border-left: 4px solid #dc3545;
    }

    .panel-adelanto {
        background: #eff6ff;
        border-left: 4px solid #0d6efd;
    }

    .panel-ok {
        background: #f0fff4;
        border-left: 4px solid #198754;
    }

    .panel-en-proceso {
        background: #fffbeb;
        border-left: 4px solid #ff8c00;
    }

    .panel-sin-inicio {
        background: #f8f9fa;
        border-left: 4px solid #adb5bd;
    }

    .panel-sin-programar {
        background: #f8f9fa;
        border-left: 4px solid #adb5bd;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // ─────────────────────────────────────────────────────────────────────────
        // 1. CONTADOR Y LÍMITE DE 200 PALABRAS
        // ─────────────────────────────────────────────────────────────────────────
        const MAX_PALABRAS = 200;
        const txtObs       = document.getElementById('txtObservaciones');
        const contador     = document.getElementById('contadorPalabras');
        const barra        = document.getElementById('barraProgreso');
        const alertaMax    = document.getElementById('alertaPalabras');

        function contarPalabras(texto) {
            const limpio = texto.trim();
            return limpio === '' ? 0 : limpio.split(/\s+/).length;
        }

        function actualizarContador() {
            const palabras = contarPalabras(txtObs.value);
            const pct      = Math.min((palabras / MAX_PALABRAS) * 100, 100);

            contador.textContent = `${palabras} / ${MAX_PALABRAS} palabras`;

            barra.style.width       = pct + '%';
            barra.setAttribute('aria-valuenow', pct);

            if (palabras >= MAX_PALABRAS) {
                barra.style.backgroundColor = '#dc3545';
                contador.className          = 'text-danger fw-semibold';
                alertaMax.classList.remove('d-none');
            } else if (palabras >= MAX_PALABRAS * 0.85) {
                barra.style.backgroundColor = '#ffc107';
                contador.className          = 'text-warning fw-semibold';
                alertaMax.classList.add('d-none');
            } else {
                barra.style.backgroundColor = '#1D3557';
                contador.className          = 'text-muted fw-semibold';
                alertaMax.classList.add('d-none');
            }
        }

        // Impedir que se escriba más de 200 palabras
        txtObs.addEventListener('keydown', function (e) {
            const permitidas = ['Backspace','Delete','ArrowLeft','ArrowRight',
                                'ArrowUp','ArrowDown','Home','End','Tab'];
            if (permitidas.includes(e.key)) return;
            if (e.ctrlKey || e.metaKey)    return; // Ctrl+A, Ctrl+C, etc.

            if (contarPalabras(this.value) >= MAX_PALABRAS) {
                // Solo se bloquea si la última pulsación no borra texto
                const selLen = window.getSelection()?.toString().length ?? 0;
                if (selLen === 0) {
                    e.preventDefault();
                    alertaMax.classList.remove('d-none');
                }
            }
        });

        // También recortar si se pega texto que supera el límite
        txtObs.addEventListener('paste', function (e) {
            e.preventDefault();
            const pegado     = (e.clipboardData || window.clipboardData).getData('text');
            const actual     = this.value;
            const palabrasAct = contarPalabras(actual);
            const palabrasPeg = contarPalabras(pegado);

            if (palabrasAct >= MAX_PALABRAS) return;

            const restante = MAX_PALABRAS - palabrasAct;
            const tokens   = pegado.trim().split(/\s+/).slice(0, restante);
            const start    = this.selectionStart;
            const end      = this.selectionEnd;
            const nuevoVal = actual.slice(0, start) + tokens.join(' ') + actual.slice(end);
            this.value = nuevoVal;
            actualizarContador();
        });

        txtObs.addEventListener('input', actualizarContador);
        actualizarContador(); // Inicializar al cargar

        // ─────────────────────────────────────────────────────────────────────────
        // 2. PANEL DINÁMICO DE DESFASE
        //    Se actualiza al cambiar las fechas estimadas, usando la fecha real
        //    que ya está cargada (campo oculto #valorFechaIniReal).
        // ─────────────────────────────────────────────────────────────────────────
        const panelDin  = document.getElementById('panelDesfaseDinamico');
        const iconoDin  = document.getElementById('iconoDesfaseDinamico');
        const textoDin  = document.getElementById('textoDesfaseDinamico');

        function calcularDesfase() {
            const fechaIniEstStr  = document.getElementById('inputFechaIniEst')?.value  || '';
            const fechaIniRealStr = document.getElementById('valorFechaIniReal')?.value || '';

            // Si no hay fecha estimada: ocultar panel dinámico
            if (!fechaIniEstStr) {
                panelDin.classList.add('d-none');
                return;
            }

            // Si no hay fecha real: mostrar "sin iniciar"
            if (!fechaIniRealStr) {
                panelDin.className   = 'mt-3 p-3 rounded-3 d-flex align-items-center gap-3 panel-sin-inicio';
                iconoDin.className   = 'bi bi-clock text-secondary fs-2';
                textoDin.textContent = 'Sin fecha real — vista previa no disponible';
                return;
            }

            const est  = new Date(fechaIniEstStr);
            const real = new Date(fechaIniRealStr);
            const diff = Math.round((real - est) / (1000 * 60 * 60 * 24));

            panelDin.classList.remove('d-none');

            if (diff > 0) {
                panelDin.className   = 'mt-3 p-3 rounded-3 d-flex align-items-center gap-3 panel-atraso';
                iconoDin.className   = 'bi bi-exclamation-triangle text-danger fs-2';
                textoDin.textContent = `${diff} día${diff === 1 ? '' : 's'} de ATRASO`;
            } else if (diff < 0) {
                panelDin.className   = 'mt-3 p-3 rounded-3 d-flex align-items-center gap-3 panel-adelanto';
                iconoDin.className   = 'bi bi-check-circle text-primary fs-2';
                textoDin.textContent = `${Math.abs(diff)} día${Math.abs(diff) === 1 ? '' : 's'} ADELANTADO`;
            } else {
                panelDin.className   = 'mt-3 p-3 rounded-3 d-flex align-items-center gap-3 panel-ok';
                iconoDin.className   = 'bi bi-check2-all text-success fs-2';
                textoDin.textContent = 'EN TIEMPO';
            }
        }

        // Recalcular al cambiar fechas estimadas
        document.getElementById('inputFechaIniEst')?.addEventListener('change', calcularDesfase);
        document.getElementById('inputFechaFinEst')?.addEventListener('change', calcularDesfase);

        // Calcular al cargar la página
        window.addEventListener('DOMContentLoaded', calcularDesfase);
    </script>
}
