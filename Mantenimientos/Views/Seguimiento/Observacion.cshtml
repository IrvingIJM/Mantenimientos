@model Mantenimientos.Models.ViewModels.ObservacionVM

@{
    bool esNuevo = Model.ID == 0;
    ViewData["Title"] = esNuevo ? "Nueva Observación" : "Editar Observación";

    string FormatInput(DateTime? fecha) =>
        fecha.HasValue && fecha.Value != new DateTime(1900, 1, 1)
        ? fecha.Value.ToString("yyyy-MM-dd")
        : string.Empty;
}

    <div class="d-flex align-items-center mb-4 gap-3">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-circle p-2">
            <i class="bi bi-arrow-left"></i>
        </a>
        <div>
            <h1 class="h3 fw-bold mb-0">
                <i class="bi bi-@(esNuevo ? "plus-circle" : "pencil-square") text-primary me-2"></i>
                @ViewData["Title"]
            </h1>
            <p class="text-muted mb-0 small">
                @(esNuevo
                ? "Registrar una nueva observación."
                : $"Editando registro #{Model.ID}")
            </p>
        </div>
    </div>

    <form asp-action="Observacion" method="post" id="formObservacion" novalidate>
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ID" />

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header section-header-empresa py-3">
                <i class="bi bi-building me-2"></i>

            </div>
            <div class="card-body">
                <div class="row g-4">
                    <div class="col-12 col-md-6">
                        <label asp-for="Ruta" class="form-label fw-semibold">
                            Ruta <span class="text-danger">*</span>
                        </label>
                        <select asp-for="Ruta"
                                class="form-select"
                                id="selectRuta"
                                required>
                            <option value="">— Selecciona una ruta —</option>
                            @foreach (var ruta in Model.RutasDisponibles)
                            {
                                <option value="@ruta.Value" selected="@(ruta.Value == Model.RUTA.ToString() ? "selected" : null)">
                                    @ruta.Text
                                </option>
                            }
                        </select>
                        <span asp-validation-for="Ruta" class="text-danger small"></span>
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="Sucursal" class="form-label fw-semibold">
                            Sucursal <span class="text-danger">*</span>
                        </label>
                        <select asp-for="Sucursal"
                                class="form-select"
                                id="selectSucursal"
                                required>
                            <option value="">— Selecciona primero una ruta —</option>
                            @foreach (var item in Model.SucursalesDisponibles)
                            {
                                <option value="@item.Value" selected="@(item.Value == Model.SUCURSAL ? "selected" : null)">
                                    @item.Text
                                </option>
                            }
                        </select>
                        <span asp-validation-for="Sucursal" class="text-danger small"></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Fechas Estimadas -->
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header section-header-est py-3">
                <i class="bi bi-calendar-event me-2"></i>
                <strong>Fechas Estimadas</strong>
            </div>
            <div class="card-body">
                <div class="row g-4">
                    <div class="col-12 col-md-6">
                        <label asp-for="FechaInicioEstimada" class="form-label fw-semibold">
                            Fecha Inicio Estimada
                        </label>
                        <div class="input-group">
                            <span class="input-group-text bg-light">
                                <i class="bi bi-calendar-plus text-secondary"></i>
                            </span>
                            <input asp-for="FechaInicioEstimada"
                                   type="date"
                                   class="form-control"
                                   id="inputFechaIniEst"
                                   value="@FormatInput(Model.FECHA_INI_ES)" />
                        </div>
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="FechaFinEstimada" class="form-label fw-semibold">
                            Fecha Fin Estimada
                        </label>
                        <div class="input-group">
                            <span class="input-group-text bg-light">
                                <i class="bi bi-calendar-minus text-secondary"></i>
                            </span>
                            <input asp-for="FechaFinEstimada"
                                   type="date"
                                   class="form-control"
                                   id="inputFechaFinEst"
                                   value="@FormatInput(Model.FECHA_FIN_ES)" />
                        </div>
                        <small class="text-muted">
                            <i class="bi bi-info-circle me-1"></i>
                        </small>
                    </div>
                </div>
            </div>
        </div>

        <!-- CAlculo de atraso (se guardan en mttos) -->
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header section-header-real py-3">
                <i class="bi bi-calendar-check me-2"></i>
                <strong>Fechas Reales</strong>
            </div>
            <div class="card-body">
                <div class="row g-4">
                    <div class="col-12 col-md-6">
                        <label asp-for="FechaInicioReal" class="form-label fw-semibold">
                            Fecha Inicio Real
                        </label>
                        <div class="input-group">
                            <span class="input-group-text bg-success-subtle">
                                <i class="bi bi-play-circle text-success"></i>
                            </span>
                            <input asp-for="FechaInicioReal"
                                   type="date"
                                   class="form-control"
                                   id="inputFechaIniReal"
                                   value="@FormatInput(Model.FECHA_INI_RE)"
                                   onchange="calcularDesfase()" />
                        </div>
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="FechaFinReal" class="form-label fw-semibold">
                            Fecha Fin Real
                        </label>
                        <div class="input-group">
                            <span class="input-group-text bg-success-subtle">
                                <i class="bi bi-stop-circle text-success"></i>
                            </span>
                            <input asp-for="FechaFinReal"
                                   type="date"
                                   class="form-control"
                                   id="inputFechaFinReal"
                                   value="@FormatInput(Model.FECHA_FIN_RE)"
                                   onchange="calcularDesfase()" />
                        </div>
                    </div>

                    <!-- Indicador de dias calculado -->
                    <div class="col-12">
                        <div id="panelDesfase" class="desfase-panel rounded p-3 d-none">
                            <div class="d-flex align-items-center gap-3">
                                <i class="bi bi-stopwatch fs-3" id="iconDesfase"></i>
                                <div>
                                    <div class="fw-bold fs-5" id="textoDesfase">—</div>
                                    <small class="text-muted" id="subTextoDesfase">
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Observaciones -->
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white border-bottom py-3">
                <i class="bi bi-chat-square-text text-primary me-2"></i>
                <strong>Observaciones</strong>
            </div>
            <div class="card-body">
                <label asp-for="Observaciones" class="form-label fw-semibold">
                    Detalle del mantenimiento
                </label>
                <textarea asp-for="Observaciones"
                          class="form-control"
                          rows="5"
                          id="txtObservaciones"
                          placeholder="Describe el estado del mantenimiento, incidencias encontradas,
                materiales utilizados, etc."></textarea>
                <div class="d-flex justify-content-between mt-1">
                    <small class="text-muted" id="contadorChars">0 caracteres</small>
                </div>
            </div>
        </div>

        <!-- Botones de acción -->
        <div class="d-flex gap-3 justify-content-end pt-2">
            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                <i class="bi bi-x-circle me-1"></i>Cancelar
            </a>
            <button type="submit" class="btn btn-primary px-5 shadow-sm">
                <i class="bi bi-@(esNuevo ? "save" : "check-circle") me-2"></i>
                @(esNuevo ? "Guardar Observación" : "Actualizar Registro")
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // Calculo de dias desfasados
        function calcularDesfase() {
            const fechaFinEst  = document.getElementById('inputFechaFinEst').value;
            const fechaFinReal = document.getElementById('inputFechaFinReal').value;
            const panel = document.getElementById('panelDesfase');
            const texto = document.getElementById('textoDesfase');
            const icono = document.getElementById('iconDesfase');

            if (!fechaFinEst || !fechaFinReal) {
                panel.classList.add('d-none');
                return;
            }
            const est  = new Date(fechaFinEst);
            const real = new Date(fechaFinReal);
            const diff = Math.round((real - est) / (1000 * 60 * 60 * 24));

            panel.classList.remove('d-none', 'desfase-atraso', 'desfase-ok', 'desfase-adelanto');

            if (diff > 0) {
                texto.textContent = `${diff} día(s) de ATRASO`;
                panel.classList.add('desfase-atraso');
                icono.className = 'bi bi-exclamation-triangle fs-3 text-danger';
            } else if (diff < 0) {
                texto.textContent = `${Math.abs(diff)} día(s) ADELANTADO`;
                panel.classList.add('desfase-adelanto');
                icono.className = 'bi bi-check-circle fs-3 text-success';
            } else {
                texto.textContent = 'EN TIEMPO';
                panel.classList.add('desfase-ok');
                icono.className = 'bi bi-check2-all fs-3 text-success';
            }
        }

        // Carga dinámica de sucursales al cambiar ruta (BD empresa)
        document.getElementById('selectRuta').addEventListener('change', async function () {
            const ruta        = this.value;
            const selSucursal = document.getElementById('selectSucursal');
            const inpIni      = document.getElementById('inputFechaIniEst');
            const inpFin      = document.getElementById('inputFechaFinEst');

            selSucursal.innerHTML = '<option value="">Cargando sucursales…</option>';
            selSucursal.disabled  = true;
            inpIni.value = '';
            inpFin.value = '';

            if (!ruta) {
                selSucursal.innerHTML = '<option value="">— Selecciona primero una ruta —</option>';
                selSucursal.disabled  = false;
                return;
            }
            try {
                const res  = await fetch(`/Seguimiento/ObtenerSucursales?ruta=${encodeURIComponent(ruta)}`);
                const data = await res.json();
                selSucursal.innerHTML = '<option value="">— Selecciona una sucursal —</option>';
                data.forEach(function (s) {
                    const opt       = document.createElement('option');
                    opt.value       = s;
                    opt.textContent = s;
                    selSucursal.appendChild(opt);
                });
            } catch (e) {
                console.error('Error al cargar sucursales:', e);
                selSucursal.innerHTML = '<option value="">Error al cargar</option>';
            }
            selSucursal.disabled = false;
        });

        // Carga automatica de fechas estimadas al seleccionar sucursal
        document.getElementById('selectSucursal').addEventListener('change', async function () {
            const ruta     = document.getElementById('selectRuta').value;
            const sucursal = this.value;
            if (!ruta || !sucursal) return;
            try {
                const url  = `/Seguimiento/ObtenerFechasEstimadas?ruta=${encodeURIComponent(ruta)}&sucursal=${encodeURIComponent(sucursal)}`;
                const res  = await fetch(url);
                const data = await res.json();
                document.getElementById('inputFechaIniEst').value = data.fechaIniEst || '';
                document.getElementById('inputFechaFinEst').value = data.fechaFinEst || '';
                calcularDesfase();
            } catch (e) {
                console.error('Error al cargar fechas estimadas:', e);
            }
        });

        // Contador de caracteres
        const txtObs   = document.getElementById('txtObservaciones');
        const contador = document.getElementById('contadorChars');

        function actualizarContador() {
            const len      = txtObs.value.length;
            contador.textContent = `${len} caracteres`;
            contador.className   = len > 3800 ? 'text-danger small' : 'text-muted small';
        }
        txtObs.addEventListener('input', actualizarContador);
        actualizarContador();

        // Calcular desfase al cargar (modo edición)
        window.addEventListener('DOMContentLoaded', calcularDesfase);
    </script>
}
