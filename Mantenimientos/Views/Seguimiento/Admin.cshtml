@{
    ViewData["Title"] = "Cargar periodo";
    int periodoActual = (int)(ViewBag.PeriodoActual ?? 0);
}

<div class="container py-4" style="max-width:860px;">

    <!-- Botón de regreso y título  -->
    <div class="d-flex align-items-center mb-4 gap-3">
        <a href="@Url.Action("Index", "Seguimiento")" class="btn btn-outline-secondary btn-sm rounded-circle p-2">
            <i class="bi bi-arrow-left"></i>
        </a>
        <div>
            <h1 class="h4 fw-bold mb-0">Cargar Periodo</h1>
        </div>
    </div>

    <!-- Mensaje de alerta si existe -->
    @if (TempData["Mensaje"] != null)
    {
        var tipo = TempData["TipoAlerta"]?.ToString() ?? "success";
        <div class="alert alert-@tipo alert-dismissible fade show shadow-sm mb-4" role="alert">
            <i class="bi bi-info-circle-fill me-2"></i> @TempData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Tarjeta de importación de periodo -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header py-3"
             style="color:#fff; background:#1D3557;">
            <span class="fw-semibold">Importación de periodo</span>
        </div>
        <div class="card-body">
            <p class="mb-2">
                Periodo actual detectado: Periodo @periodoActual
            </p>
            <p class="text-muted small mb-4">
                Esta acción agrega a <strong>Seguimientos</strong> las sucursales activas que todavía no tengan un registro para el periodo actual.
            </p>

            <button type="button" id="btnCargarPeriodo"
                    class="btn fw-semibold shadow-sm px-4 d-inline-flex align-items-center gap-2"
                    style="background:#1D3557; border-color:#1D3557; color:#fff;">
                <i class="bi bi-cloud-arrow-up-fill fs-5"></i>Cargar periodo
            </button>
        </div>
    </div>
</div>

<!-- Modal de confirmación antes de ejecutar la importación -->
<div class="modal fade" id="modalConfirmarCarga" tabindex="-1" aria-labelledby="modalConfirmarCargaLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header" style="background:#1D3557; color:#fff;">
                <h5 class="modal-title" id="modalConfirmarCargaLabel">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>Confirmar carga de periodo
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">
                    ¿Deseas cargar las sucursales activas pendientes para el
                    <strong>Periodo @periodoActual</strong>?
                </p>
                <p class="text-muted small mt-2 mb-0">
                    Las sucursales que ya tengan registro en este periodo no se verán afectadas.
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form id="formCargarPeriodo" method="post" asp-action="Importar" asp-controller="Seguimiento" class="mb-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn fw-semibold" id="btnConfirmarCarga"
                            style="background:#1D3557; border-color:#1D3557; color:#fff;">
                        <i class="bi bi-check-lg me-2"></i>Sí, cargar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Mostrar el modal de confirmación al hacer clic en el botón de cargar periodo
        document.getElementById('btnCargarPeriodo').addEventListener('click', () => {
            const modal = new bootstrap.Modal(document.getElementById('modalConfirmarCarga'));
            modal.show();
        });

        // Deshabilitar el botón de confirmación y mostrar un indicador de carga al enviar el formulario
        document.getElementById('formCargarPeriodo').addEventListener('submit', () => {
            const btn = document.getElementById('btnConfirmarCarga');
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-hourglass-split me-2"></i>Cargando...';
        });
    </script>
}
