@model Mantenimientos.Models.ViewModels.IndexVM

@{
    ViewData["Title"] = "Consulta de Mantenimientos";
}

@functions {
    static string FormatFecha(DateTime? fecha) =>
        (!fecha.HasValue || fecha.Value <= new DateTime(1900, 1, 1))
            ? "—"
            : fecha.Value.ToString("dd/MM/yyyy");

    // sistema de reportes (bimbo/barcel) a partir del prefijo de CLV_SUC.
    static string? EmpresaReporte(string clvSuc)
    {
        if (string.IsNullOrWhiteSpace(clvSuc) || clvSuc.Length < 3) return null;
        var prefijo = clvSuc.Substring(0, 3).ToUpperInvariant();
        return prefijo switch
        {
            "BIM" => "bimbo",
            "BAR" => "barcel",
            _ => null
        };
    }
}

<div class="container-fluid py-4 px-3">

    <div class="row align-items-center g-3 mb-4">
        <div class="col-12 col-sm">
            <h1 class="h3 fw-bold text-black m-0">
                Seguimiento de Mantenimientos
            </h1>
        </div>
        <div class="col-12 col-sm-auto">
            <a href="@Url.Action("Admin", "Seguimiento")"
               class="btn fw-semibold shadow-sm px-4 d-inline-flex align-items-center gap-2"
               style="background:#fff; border-color:#1D3557; color:#1D3557;">
                <i class="bi bi-gear-fill"></i>Administración
            </a>
        </div>
    </div>

    @if (TempData["Mensaje"] != null)
    {
        var tipo = TempData["TipoAlerta"]?.ToString() ?? "success";
        <div class="alert alert-@tipo alert-dismissible fade show shadow-sm mb-4" role="alert">
            <i class="bi bi-info-circle-fill me-2"></i> @TempData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Filtros -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header py-3"
             style="color:#fff; background:linear-gradient(135deg,#1D3557 0%,#457B9D 100%);">
            <span class="fw-semibold">Filtros de Búsqueda</span>
        </div>
        <div class="card-body bg-light-subtle">
            <form asp-action="Index" method="get" id="formFiltros">
                <div class="row g-3 align-items-end">

                    <!-- Filtro empresa -->
                    <div class="col-12 col-md-3">
                        <label class="form-label fw-bold text-muted small text-uppercase">Empresa</label>
                        <select name="filtroEmpresa" id="filtroEmpresa" class="form-select">
                            <option value="">— Todas —</option>
                            @if (Model.FiltroEmpresa == "BIM")
                            {
                                <option value="BIM" selected>Bimbo</option>
                            }
                            else
                            {
                                <option value="BIM">Bimbo</option>
                            }

                            @if (Model.FiltroEmpresa == "BAR")
                            {
                                <option value="BAR" selected>Barcel</option>
                            }
                            else
                            {
                                <option value="BAR">Barcel</option>
                            }
                        </select>
                    </div>

                    <!-- Filtro ruta-->
                    <div class="col-12 col-md-2">
                        <label class="form-label fw-bold text-muted small text-uppercase">Ruta</label>
                        <select name="filtroRuta" id="filtroRuta" class="form-select">
                            <option value="">— Todas —</option>
                            @foreach (var item in Model.RutasDisponibles)
                            {
                                <!option value="@item.Value" @(item.Selected ? "selected" : "")>@item.Text</!option>
                            }
                        </select>
                    </div>

                    <!-- Filtro mes (rango) -->
                    <div class="col-12 col-md-2">
                        <label class="form-label fw-bold text-muted small text-uppercase">Mes desde</label>
                        <select name="filtroMesInicio" id="filtroMesInicio" class="form-select">
                            <option value="">— Todos —</option>
                            @foreach (var item in Model.MesesDisponibles)
                            {
                                <!option value="@item.Value" @(Model.FiltroMesInicio.HasValue && Model.FiltroMesInicio.Value.ToString() == item.Value ? "selected" : "")>@item.Text</!option>
                            }
                        </select>
                    </div>
                    <div class="col-12 col-md-2">
                        <label class="form-label fw-bold text-muted small text-uppercase">Mes hasta</label>
                        <select name="filtroMesFin" id="filtroMesFin" class="form-select">
                            <option value="">— Todos —</option>
                            @foreach (var item in Model.MesesDisponibles)
                            {
                                <!option value="@item.Value" @(Model.FiltroMesFin.HasValue && Model.FiltroMesFin.Value.ToString() == item.Value ? "selected" : "")>@item.Text</!option>
                            }
                        </select>
                    </div>

                    <!-- Filtro periodo-->
                    <div class="col-12 col-md-3">
                        <label class="form-label fw-bold text-muted small text-uppercase">Periodo</label>
                        <select name="filtroPeriodo" id="filtroPeriodo" class="form-select">
                            @foreach (var item in Model.PeriodosDisponibles)
                            {
                                <!option value="@item.Value" @(item.Selected ? "selected" : "")>@item.Text</!option>
                            }
                        </select>
                    </div>

                    <!-- Switch ocultar sin fecha -->
                    <div class="col-12 col-md-3">
                        <div class="form-check form-switch mt-4 pt-1">
                            <input class="form-check-input" type="checkbox"
                                   name="ocultarSinFecha" id="ocultarSinFecha" value="true"
                            @(ViewBag.OcultarSinFecha == true ? "checked" : "")>
                            <label class="form-check-label fw-semibold text-dark" for="ocultarSinFecha">
                                <i class="bi bi-eye-slash-fill text-warning me-1"></i>Ocultar sin fecha
                            </label>
                        </div>
                    </div>

                </div>

                <!-- Botones -->
                <div class="d-flex gap-2 mt-4 pt-3 border-top flex-wrap align-items-center">
                    <button type="submit" class="btn fw-semibold shadow-sm px-4"
                            style="background:#fff; border-color:#1D3557; color:#1D3557;">
                        <i class="bi bi-search me-2"></i>Buscar
                    </button>

                    <button type="button" id="btnLimpiar"
                            class="btn btn-outline-secondary fw-semibold px-4">
                        <i class="bi bi-arrow-counterclockwise me-2"></i>Limpiar
                    </button>
                    <div class="ms-md-auto mt-2 mt-md-0">
                        <button type="button" id="btnDescargar"
                                class="btn fw-semibold shadow-sm px-4 d-inline-flex align-items-center gap-2"
                                style="background:#fff; border-color:#333; color:#333;">
                            <i class="bi bi-file-earmark-excel-fill fs-5"></i>Descargar formato
                        </button>
                    </div>
                    <div class="ms-md-auto mt-2 mt-md-0">
                        <button type="button" id="btnCargar"
                                class="btn fw-semibold shadow-sm px-4 d-inline-flex align-items-center gap-2"
                                style="background:#fff; border-color:#333; color:#333;">
                            <i class="bi bi-file-earmark-excel-fill fs-5"></i>Subir formato
                        </button>
                    </div>
                    <div class="ms-md-auto mt-2 mt-md-0">
                        <button type="button" id="btnExportar"
                                class="btn fw-semibold shadow-sm px-4 d-inline-flex align-items-center gap-2"
                                style="background:greenyellow; border-color:#333; color:#333;">
                            <i class="bi bi-file-earmark-excel-fill fs-5"></i>Exportar a Excel
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Tabla -->
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center py-3">
            <span class="badge px-3 py-2 rounded-pill fs-6 fw-bold"
                  style="background:#1D3557; color:#fff;">
                @Model.Seguimientos.Count registros
            </span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle mb-0">
                    <thead class="table-dark text-uppercase fs-7">
                        <tr style="font-size:0.78rem; letter-spacing:0.5px;">
                            <th class="ps-3 text-white py-3">Ruta</th>
                            <th class="text-white py-3 text-center">Región</th>
                            <th class="text-white py-3">Sucursal</th>
                            <th class="text-white py-3 text-center">Fecha Ini. Estimada</th>
                            <th class="text-white py-3 text-center">Fecha Fin Estimada</th>
                            <th class="text-white py-3 text-center">Fecha Ini. Real</th>
                            <th class="text-white py-3 text-center">Fecha Fin Real</th>
                            <th class="text-white py-3 text-center">Días de atraso</th>
                            <th class="text-white py-3" style="min-width:180px;">Observaciones</th>
                            <th class="text-white py-3 text-center">Acciones</th>
                            <th class="text-white py-3 text-center">Reporte</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Seguimientos.Any())
                        {
                            <tr>
                                <td colspan="11" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-2 opacity-50"></i>
                                    <p class="mb-1 fw-bold">Sin registros para el Periodo @Model.FiltroPeriodo</p>
                                    <small>Prueba cambiando filtros.</small>
                                </td>
                            </tr>
                        }
                        @foreach (var item in Model.Seguimientos)
                        {
                            var sinFechaEst = !item.FECHA_INI_ES.HasValue || item.FECHA_INI_ES <= new DateTime(1900, 1, 1);
                            var sinFechaRe = !item.FECHA_INI_RE.HasValue;
                            var sinFinReal = !item.FECHA_FIN_RE.HasValue;

                            int diasDif = 0;
                            if (!sinFechaEst && !sinFechaRe)
                                diasDif = (item.FECHA_INI_RE!.Value.Date - item.FECHA_INI_ES!.Value.Date).Days;

                            <tr>
                                <td class="ps-3 fw-bold text-primary">@item.RUTA</td>
                                <td class="text-muted">@item.REGION_NOMBRE</td>
                                <td class="fw-semibold text-dark">@item.SUCURSAL</td>
                                <td class="text-center">@FormatFecha(item.FECHA_INI_ES)</td>
                                <td class="text-center">@FormatFecha(item.FECHA_FIN_ES)</td>
                                <td class="text-center">@FormatFecha(item.FECHA_INI_RE)</td>
                                <td class="text-center">@FormatFecha(item.FECHA_FIN_RE)</td>
                                <td class="text-center">
                                    @if (sinFechaEst)
                                    {
                                        <span class="badge bg-secondary rounded-pill px-3">No programado</span>
                                    }
                                    else if (sinFechaRe)
                                    {
                                        <span class="badge bg-secondary rounded-pill px-3">No iniciado</span>
                                    }
                                    else if (sinFinReal)
                                    {
                                        <span class="badge rounded-pill px-3" style="background:#FF8C00;">En proceso</span>
                                    }
                                    else if (diasDif > 0)
                                    {
                                        <span class="badge bg-danger rounded-pill px-3">@diasDif días</span>
                                    }
                                    else if (diasDif < 0)
                                    {
                                        <span class="badge rounded-pill px-3" style="background:#007BFF;">
                                            @diasDif días
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success rounded-pill px-3">En tiempo</span>
                                    }
                                </td>
                                <td class="text-secondary small text-truncate" style="max-width:200px;">
                                    @if (!string.IsNullOrWhiteSpace(item.OBSERVACIONES))
                                    {
                                        <span data-bs-toggle="tooltip" title="@item.OBSERVACIONES">
                                            @item.OBSERVACIONES
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a href="@Url.Action("Observacion", "Seguimiento", new { id = item.ID })"
                                       class="btn btn-sm btn-outline-primary rounded-pill px-3 fw-semibold">
                                        <i class="bi bi-pencil me-1"></i>Editar
                                    </a>
                                </td>
                                <td class="text-center">
                                    @{
                                        var empresaReporte = EmpresaReporte(item.CLV_SUC);
                                    }
                                    @if (empresaReporte != null)
                                    {
                                        var urlReporte = $"{Model.ReporteUrl.TrimEnd('/')}/{empresaReporte}/Observaciones.aspx?clv={Uri.EscapeDataString(item.CLV_SUC)}&p={item.ID_PERIODO}";
                                        <a href="@urlReporte" target="_blank" rel="noopener"
                                           class="btn btn-sm btn-outline-primary align-content-md-stretch px-3 fw-semibold">
                                            Reporte
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary rounded-pill px-3" title="No se pudo determinar la empresa para esta sucursal">
                                            N/D
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal para subir archivo de excel -->
<div class="modal fade" id="modalSubirFormato" tabindex="-1" aria-labelledby="modalSubirFormatoLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header" style="background:#1D3557; color:#fff;">
                <h5 class="modal-title" id="modalSubirFormatoLabel">
                    Subir Archivo Excel
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="formSubirArchivo" method="post" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label for="archivoExcel" class="form-label fw-bold">Selecciona un archivo Excel</label>
                        <input type="file" class="form-control" id="archivoExcel" name="archivo" accept=".xlsx,.xls" required>
                        <small class="form-text text-muted d-block mt-2"></small>
                    </div>
                    <input type="hidden" id="filtroPeriodoModal" name="filtroPeriodo">
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="submit" class="btn btn-primary fw-semibold" form="formSubirArchivo" id="btnEnviarArchivo">
                    <i class="bi bi-upload me-2"></i>Subir
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // URLs generadas por Razor
        const urlExportar = '@Url.Action("Exportar", "Seguimiento")';
        const urlIndex = '@Url.Action("Index", "Seguimiento")';
        const urlDescargar = '@Url.Action("Descargar", "Seguimiento")';
        const urlCargar = '@Url.Action("Cargar", "Seguimiento")';

        // Tooltips
        document.querySelectorAll('[data-bs-toggle="tooltip"]')
                .forEach(el => new bootstrap.Tooltip(el));

        // Restringe "Mes hasta" para que no se pueda elegir un mes anterior al de "Mes desde"
        function limitarMesFin() {
            const selInicio = document.getElementById('filtroMesInicio');
            const selFin = document.getElementById('filtroMesFin');
            if (!selInicio || !selFin) return;

            const mesInicio = parseInt(selInicio.value, 10);

            Array.from(selFin.options).forEach(opt => {
                if (!opt.value) { opt.disabled = false; return; }
                const mesOpt = parseInt(opt.value, 10);
                opt.disabled = !isNaN(mesInicio) && mesOpt < mesInicio;
            });

            // Si el mes fin ya seleccionado quedó inválido con el nuevo mes inicio, se limpia
            if (!isNaN(mesInicio) && selFin.value) {
                const mesFinActual = parseInt(selFin.value, 10);
                if (mesFinActual < mesInicio) {
                    selFin.value = '';
                }
            }
        }

        document.getElementById('filtroMesInicio')?.addEventListener('change', limitarMesFin);
        window.addEventListener('DOMContentLoaded', limitarMesFin);

        // vuelve al Index sin filtros (muestra periodo actual por defecto)
        document.getElementById('btnLimpiar').addEventListener('click', () => {
            window.location.href = urlIndex;
        });

        // Descargar formato
        document.getElementById('btnDescargar').addEventListener('click', () => {
            const p = new URLSearchParams();
            window.location.href = urlDescargar + '?' + p.toString();
        });

        // Cargar formato,abre el modal
        document.getElementById('btnCargar').addEventListener('click', () => {
            const periodo = document.getElementById('filtroPeriodo')?.value;
            document.getElementById('filtroPeriodoModal').value = periodo || '';

            // Abre el modal
            const modal = new bootstrap.Modal(document.getElementById('modalSubirFormato'));
            modal.show();
        });
        
        document.getElementById('formSubirArchivo').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const inputArchivo = document.getElementById('archivoExcel');
            const archivo = inputArchivo.files[0];

            // Validar que exista un archivo
            if (!archivo) {
                alert('Por favor, selecciona un archivo.');
                return;
            }

            // Validar extensión
            const extensionesPermitidas = ['xlsx', 'xls'];
            const extension = archivo.name.split('.').pop().toLowerCase();

            if (!extensionesPermitidas.includes(extension)) {
                alert('Solo se permiten archivos de Excel (.xlsx o .xls).');
                inputArchivo.value = '';
                return;
            }

            // Validar tipo MIME
            const tiposPermitidos = [
                'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',
                'application/vnd.ms-excel'
            ];

            if (!tiposPermitidos.includes(archivo.type)) {
                alert('El archivo seleccionado no es un archivo de Excel válido.');
                inputArchivo.value = '';
                return;
            }

            const btnEnviar = document.getElementById('btnEnviarArchivo');
            btnEnviar.disabled = true;
            btnEnviar.innerHTML = '<i class="bi bi-hourglass-split me-2"></i>Procesando...';

            const formData = new FormData();
            formData.append('archivo', archivo);

            const periodo = document.getElementById('filtroPeriodoModal').value;

            if (periodo && periodo.trim() !== '') {
                formData.append('filtroPeriodo', parseInt(periodo));
            }

            try {

                const response = await fetch(urlCargar, {
                    method: 'POST',
                    body: formData
                });

                if (response.redirected) {
                    window.location.href = response.url;
                    return;
                }

                if (response.ok) {
                    window.location.reload();
                    return;
                }

                alert('Ocurrió un error al subir el archivo.');

            } catch (error) {

                console.error(error);
                alert('Error: ' + error.message);

            } finally {

                btnEnviar.disabled = false;
                btnEnviar.innerHTML = '<i class="bi bi-upload me-2"></i>Subir';

            }
        });
        // Exportar con los mismos filtros activos
        document.getElementById('btnExportar').addEventListener('click', () => {
            const p = new URLSearchParams();
            const ruta = document.getElementById('filtroRuta')?.value;
            const empresa = document.getElementById('filtroEmpresa')?.value;
            const mesInicio = document.getElementById('filtroMesInicio')?.value;
            const mesFin = document.getElementById('filtroMesFin')?.value;
            const periodo = document.getElementById('filtroPeriodo')?.value;
            const ocultar = document.getElementById('ocultarSinFecha')?.checked;

            if (ruta) p.append('filtroRuta', ruta);
            if (empresa) p.append('filtroEmpresa', empresa);
            if (mesInicio) p.append('filtroMesInicio', mesInicio);
            if (mesFin) p.append('filtroMesFin', mesFin);
            if (periodo) p.append('filtroPeriodo', periodo);
            if (ocultar) p.append('ocultarSinFecha', 'true');

            window.location.href = urlExportar + '?' + p.toString();
        });
    </script>
}
