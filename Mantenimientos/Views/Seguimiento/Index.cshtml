@model Mantenimientos.Models.ViewModels.IndexVM

@{
    ViewData["Title"] = "Consulta de Mantenimientos";
}

@section Styles {
    <style>
        /* Texto blanco sólo en las áreas oscuras relevantes */
        .seg-seguimiento .card-header,
        .seg-seguimiento .table-dark thead th,
        .seg-seguimiento .badge,
        .seg-seguimiento .btn.btn-primary {
            color: #ffffff !important;
        }

        /* Si se desea todo el contenido en blanco dentro del contenedor */
        .seg-seguimiento { color: #ffffff; }
    </style>
}


@functions {
    static string FormatFecha(DateTime? fecha) =>
        (!fecha.HasValue || fecha.Value == new DateTime(1900, 1, 1)) ? "—" : fecha.Value.ToString("dd/MM/yyyy");

    static string ClaseDias(int dias)
    {
        if (dias > 0) return "badge bg-danger text-white fs-7";
        if (dias < 0) return "badge bg-success text-white fs-7";
        return "badge bg-secondary text-white fs-7";
    }

    static string TextoDias(int dias)
    {
        if (dias > 0) return $"-{dias} días";
        if (dias < 0) return $"{dias} días";
        return "En tiempo";
    }
}

<div class="container-fluid py-4 px-3">

    <div class="row align-items-center g-3 mb-4">
        <div class="col-12 col-sm">
            <h1 class="h3 fw-bold text-black m-0 d-flex align-items-center gap-2">
                <i class="bi bi-clipboard2-data text-primary"></i>
                Seguimiento de Mantenimientos
            </h1>
        </div>
        <div class="col-12 col-sm-auto text-sm-end">
            <a href="@Url.Action("Observacion", "Seguimiento")" class="btn btn-primary d-inline-flex align-items-center gap-2 shadow-sm fw-semibold">
                <i class="bi bi-plus-circle-fill"></i>
                Nueva Observación
            </a>
        </div>
    </div>

    @if (TempData["Mensaje"] != null)
    {
        var tipo = TempData["TipoAlerta"]?.ToString() ?? "success";
        <div class="alert alert-@tipo alert-dismissible fade show shadow-sm mb-4" role="alert">
            <i class="bi bi-info-circle-fill me-2"></i> @TempData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header py-3 d-flex align-items-center gap-2"
             style="background: linear-gradient(135deg, #1D3557 0%, #457B9D 100%);">
            <i class="bi bi-funnel-fill text-white"></i>
            <span class="text-white fw-semibold m-0">Filtros de Búsqueda</span>
        </div>
        <div class="card-body bg-light-subtle">
            <form asp-action="Index" method="get" id="formFiltros">
                <div class="row g-3">
                    <div class="col-12 col-md-4">
                        <label class="form-label fw-bold text-muted small text-uppercase">
                            <i class="bi bi-signpost me-1"></i>Ruta
                        </label>

                        <select name="filtroRuta" id="filtroRuta" class="form-select border-2">
                            <option value="">— Todas las rutas —</option>
                            @foreach (var item in Model.RutasDisponibles)
                            {
                                if (item.Selected)
                                {
                                    <option value="@item.Value" selected>@item.Text</option>
                                }
                                else
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label fw-bold text-muted small text-uppercase">
                            <i class="bi bi-shop me-1"></i>Sucursal
                        </label>
                       
                        <select name="filtroSucursal" id="filtroSucursal" class="form-select border-2">
                            <option value="">— Todas las sucursales —</option>
                            @foreach (var item in Model.SucursalesDisponibles)
                            {
                                if (item.Selected)
                                {
                                    <option value="@item.Value" selected>@item.Text</option>
                                }
                                else
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label fw-bold text-muted small text-uppercase">
                            <i class="bi bi-calendar3 me-1"></i>Mes
                        </label>
                        <select name="filtroMes" id="filtroMes" class="form-select border-2">
                            <option value="">— Todos los meses —</option>
                            @foreach (var item in Model.MesesDisponibles)
                            {
                                if (item.Selected)
                                {
                                    <option value="@item.Value" selected>@item.Text</option>
                                }
                                else
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            }
                        </select>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4 pt-3 border-top flex-wrap align-items-center">
                    <button type="submit" class="btn btn-primary px-4 fw-semibold shadow-sm"
                            style="background-color: #1D3557; border-color: #1D3557;">
                        <i class="bi bi-search me-2"></i>Buscar
                    </button>

                    <button type="button" id="btnLimpiar" class="btn btn-outline-secondary px-4 fw-semibold">
                        <i class="bi bi-arrow-counterclockwise me-2"></i>Limpiar
                    </button>

                    <div class="ms-md-auto col-12 col-md-auto text-end mt-2 mt-md-0">
                        <a id="btnExportar"
                           href="@Url.Action("Exportar", "Seguimiento", new { filtroRuta = Model.FiltroRuta, filtroSucursal = Model.FiltroSucursal, filtroMes = Model.FiltroMes })"
                           role="button"
                           class="btn btn-success d-inline-flex align-items-center gap-2 px-4 fw-semibold shadow-sm"
                           style="background-color: greenyellow; border-color: black;">
                            <i class="bi bi-file-earmark-excel-fill fs-5"></i>
                            Exportar a Excel
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center py-3">
            <span class="fw-bold text-dark m-0"></span>
            <span class="badge bg-primary px-3 py-2 rounded-pill fs-6 fw-bold"
                  style="background-color: #1D3557 !important;">
                @Model.Seguimientos.Count registros
            </span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle mb-0" id="tablaMantenimientos">
                    <thead class="table-dark" style="background-color: #1D3557;">
                        <tr class="align-middle text-uppercase" style="font-size: 0.8rem; letter-spacing: 0.5px;">
                            <th class="ps-4 text-white py-3">Ruta</th>
                            <th class="text-white py-3">Sucursal</th>
                            <th class="text-white py-3">F. Ini. Est.</th>
                            <th class="text-white py-3">F. Fin Est.</th>
                            <th class="text-white py-3">F. Ini. Real</th>
                            <th class="text-white py-3">F. Fin Real</th>
                            <th class="text-center text-white py-3">Días Atraso</th>
                            <th class="text-white py-3" style="min-width: 180px;">Observaciones</th>
                            <th class="text-center text-white py-3">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Seguimientos.Any())
                        {
                            <tr>
                                <td colspan="9" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-2 opacity-50 text-secondary"></i>
                                    <p class="mb-1 fw-bold">No se encontraron registros coincidentes</p>
                                    <small class="text-muted">Prueba cambiando los criterios de los filtros superiores.</small>
                                </td>
                            </tr>
                        }
                        @foreach (var item in Model.Seguimientos)
                        {
                            var esAtrasado = item.DIAS_ATRASO > 0;
                            <tr class="@(esAtrasado ? "table-danger-subtle" : "")">
                                <td class="ps-4 fw-bold text-primary">@item.RUTA</td>
                                <td class="fw-semibold text-dark">@item.SUCURSAL</td>
                                <td class="text-muted small">@FormatFecha(item.FECHA_INI_ES)</td>
                                <td class="text-muted small">@FormatFecha(item.FECHA_FIN_ES)</td>
                                <td class="fw-medium">@FormatFecha(item.FECHA_INI_RE)</td>
                                <td class="fw-medium">@FormatFecha(item.FECHA_FIN_RE)</td>
                                <td class="text-center">
                                    <span class="@ClaseDias(item.DIAS_ATRASO) rounded-pill px-3 py-1 fw-bold">
                                        @TextoDias(item.DIAS_ATRASO)
                                    </span>
                                </td>
                                <td class="text-secondary small text-truncate" style="max-width: 250px;">
                                    @if (!string.IsNullOrWhiteSpace(item.OBSERVACIONES))
                                    {
                                        <span data-bs-toggle="tooltip" data-bs-placement="top" title="@item.OBSERVACIONES">
                                            @item.OBSERVACIONES
                                        </span>
                                    }
                                    else
                                    {
                                        <em class="text-muted opacity-50">Sin observaciones</em>
                                    }
                                </td>
                                <td class="text-center">
                                    <a href="@Url.Action("Observacion", "Seguimiento", new { id = item.ID })"
                                       role="button" 
                                       class="btn btn-sm btn-outline-primary rounded-pill px-3 fw-semibold">
                                        <i class="bi bi-pencil me-1"></i>Editar
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Inicializar tooltips de Bootstrap 5
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
                new bootstrap.Tooltip(el);
            });

            // Limpiar filtros
            const btnLimpiar = document.getElementById('btnLimpiar');
            if (btnLimpiar) {
                btnLimpiar.addEventListener('click', function () {
                    const rutaSel = document.getElementById('filtroRuta');
                    const sucSel = document.getElementById('filtroSucursal');
                    const mesSel = document.getElementById('filtroMes');

                    if (rutaSel) rutaSel.value = '';
                    if (sucSel) sucSel.innerHTML = '<option value="">— Todas las sucursales —</option>';
                    if (mesSel) mesSel.value = '';

                    // Redirigir a la acción Index sin parámetros
                    window.location.href = '@Url.Action("Index", "Seguimiento")';
                });
            }

            // Exportar con filtros actuales
            const btnExportar = document.getElementById('btnExportar');
            if (btnExportar) {
                btnExportar.addEventListener('click', function (e) {
                    e.preventDefault();
                    const ruta = document.getElementById('filtroRuta')?.value || '';
                    const sucursal = document.getElementById('filtroSucursal')?.value || '';
                    const mes = document.getElementById('filtroMes')?.value || '';

                    const params = new URLSearchParams();
                    if (ruta) params.append('filtroRuta', ruta);
                    if (sucursal) params.append('filtroSucursal', sucursal);
                    if (mes) params.append('filtroMes', mes);

                    window.location.href = '/Seguimiento/Exportar?' + params.toString();
                });
            }

            // Cargar sucursales dinámicamente al cambiar ruta
            const filtroRuta = document.getElementById('filtroRuta');
            if (filtroRuta) {
                filtroRuta.addEventListener('change', async function () {
                    const ruta = this.value;
                    const selSucursal = document.getElementById('filtroSucursal');
                    if (!selSucursal) return;

                    selSucursal.innerHTML = '<option value="">Cargando...</option>';
                    if (!ruta) {
                        selSucursal.innerHTML = '<option value="">— Todas las sucursales —</option>';
                        return;
                    }

                    try {
                        const res = await fetch(`/Seguimiento/ObtenerSucursalesFiltro?ruta=${encodeURIComponent(ruta)}`);
                        const data = await res.json();
                        selSucursal.innerHTML = '<option value="">— Todas las sucursales —</option>';
                        data.forEach(function (s) {
                            const option = document.createElement('option');
                            option.value = s;
                            option.textContent = s;
                            selSucursal.appendChild(option);
                        });
                    } catch (e) {
                        console.error('Error al cargar sucursales:', e);
                        selSucursal.innerHTML = '<option value="">— Todas las sucursales —</option>';
                    }
                });
            }
        });
    </script>
}
