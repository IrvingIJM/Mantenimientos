@model Mantenimientos.Models.ViewModels.IndexVM

@{
    ViewData["Title"] = "Consulta de Mantenimientos";
}

@functions {
    static string FormatFecha(DateTime? fecha) =>
        (!fecha.HasValue || fecha.Value <= new DateTime(1900, 1, 1))
            ? "—"
            : fecha.Value.ToString("dd/MM/yyyy");
}

<div class="container-fluid py-4 px-3">

    <div class="row align-items-center g-3 mb-4">
        <div class="col-12 col-sm">
            <h1 class="h3 fw-bold text-black m-0">
                Seguimiento de Mantenimientos
            </h1>
        </div>
    </div>

    @if (TempData["Mensaje"] != null)
    {
        var tipo = TempData["TipoAlerta"]?.ToString() ?? "success";
        <div class="alert alert-@tipo alert-dismissible fade show shadow-sm mb-4" role="alert">
            <i class="bi bi-info-circle-fill me-2"></i> @TempData["Mensaje"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Filtros -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header py-3 d-flex align-items-center gap-2"
             style="color:#ffffff; background:linear-gradient(135deg,#1D3557 0%,#457B9D 100%);">
            <span class="text-white fw-semibold m-0">Filtros de Búsqueda</span>
        </div>
        <div class="card-body bg-light-subtle">
            <form asp-action="Index" method="get" id="formFiltros">
                <div class="row g-3">

                    <!-- Ruta -->
                    <div class="col-12 col-md-2">
                        <label class="form-label fw-bold text-muted small text-uppercase">Ruta</label>
                        <select name="filtroRuta" id="filtroRuta" class="form-select border-2">
                            <option value="">— Todas —</option>
                            @foreach (var item in Model.RutasDisponibles)
                            {
                                if (item.Selected)
                                {
                                    <option value="@item.Value" selected>@item.Text</option>
                                }
                                else
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            }
                        </select>
                    </div>

                    <!-- Región -->
                    <div class="col-12 col-md-2">
                        <label class="form-label fw-bold text-muted small text-uppercase">Región</label>
                        <select name="filtroRegion" id="filtroRegion" class="form-select border-2">
                            <option value="">— Todas —</option>
                                @foreach (var item in Model.RegionesDisponibles)
                                {
                                if (item.Selected)
                                {
                                    <option value="@item.Value" selected>@item.Text</option>
                                }
                                else
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                                }
                            </select>
                    </div>

                    <!-- Mes -->
                    <div class="col-12 col-md-2">
                        <label class="form-label fw-bold text-muted small text-uppercase">Mes</label>
                        <select name="filtroMes" id="filtroMes" class="form-select border-2">
                            <option value="">— Todos —</option>
                                @foreach (var item in Model.MesesDisponibles)
                                {
                                if (item.Selected)
                                {
                                    <option value="@item.Value" selected>@item.Text</option>
                                }
                                else
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                                }
                            </select>
                    </div>

                    <!-- Periodo -->
                    <div class="col-12 col-md-2">
                        <label class="form-label fw-bold text-muted small text-uppercase">Periodo</label>
                        <select name="filtroPeriodo" id="filtroPeriodo" class="form-select border-2">
                                @foreach (var item in Model.PeriodosDisponibles)
                                {
                                if (item.Selected)
                                {
                                    <option value="@item.Value" selected>@item.Text</option>
                                }
                                else
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                                }
                            </select>
                    </div>

                </div>

                <!-- ocultar sin fecha -->
                <div class="row mt-3">
                    <div class="col-12">
                        <div class="form-check form-switch ps-5">
                            <input class="form-check-input scale-115" type="checkbox"
                                   name="ocultarSinFecha" id="ocultarSinFecha" value="true"
                                   @(ViewBag.OcultarSinFecha == true ? "checked" : "")>
                            <label class="form-check-label fw-semibold text-dark ms-2" for="ocultarSinFecha">
                                <i class="bi bi-eye-slash-fill text-warning me-1"></i> Ocultar sin fecha
                            </label>
                        </div>
                    </div>
                </div>

                <!-- Botones -->
                <div class="d-flex gap-2 mt-4 pt-3 border-top flex-wrap align-items-center">
                    <button type="submit" class="btn px-4 fw-semibold shadow-sm"
                            style="background-color:white; border-color:#1D3557; color:#1D3557;">
                        <i class="bi bi-search me-2"></i>Buscar
                    </button>

                    <button type="button" id="btnLimpiar" class="btn btn-outline-secondary px-4 fw-semibold">
                        <i class="bi bi-arrow-counterclockwise me-2"></i>Limpiar
                    </button>

                    <div class="ms-md-auto col-12 col-md-auto text-end mt-2 mt-md-0">
                        <button type="button" id="btnExportar"
                                class="btn btn-success d-inline-flex align-items-center gap-2 px-4 fw-semibold shadow-sm"
                                style="background-color:greenyellow; border-color:black; color:black;">
                            <i class="bi bi-file-earmark-excel-fill fs-5"></i>
                            Exportar a Excel
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Tabla de resultados -->
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center py-3">
            <span class="fw-bold text-dark m-0"></span>
            <span class="badge px-3 py-2 rounded-pill fs-6 fw-bold"
                  style="color:#ffffff; background-color:#1D3557;">
                @Model.Seguimientos.Count registros
            </span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle mb-0">
                    <thead style="background-color:#1D3557;">
                        <tr class="align-middle text-uppercase" style="font-size:0.78rem; letter-spacing:0.5px;">
                            <th class="ps-3 text-white py-3">Ruta</th>
                            <th class="text-white py-3">Región</th>
                            <th class="text-white py-3">Sucursal</th>
                            <th class="text-white py-3">F. Ini. Est.</th>
                            <th class="text-white py-3">F. Fin Est.</th>
                            <th class="text-white py-3">F. Ini. Real</th>
                            <th class="text-white py-3">F. Fin Real</th>
                            <th class="text-center text-white py-3">Días Atraso</th>
                            <th class="text-white py-3" style="min-width:180px;">Observaciones</th>
                            <th class="text-center text-white py-3">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Seguimientos.Any())
                        {
                            <tr>
                                <td colspan="10" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-2 opacity-50"></i>
                                    <p class="mb-1 fw-bold">No se encontraron registros</p>
                                    <small>Prueba cambiando los filtros.</small>
                                </td>
                            </tr>
                        }
                        @foreach (var item in Model.Seguimientos)
                        {
                            var sinFechaEst = !item.FECHA_INI_ES.HasValue ||
                                              item.FECHA_INI_ES.Value <= new DateTime(1900, 1, 1);
                            var sinFechaRe  = !item.FECHA_INI_RE.HasValue;
                            var sinFinReal  = !item.FECHA_FIN_RE.HasValue;
                            var esAtrasado  = !sinFechaEst && item.DIAS_ATRASO > 0 && !sinFinReal;

                            <tr class="@(esAtrasado ? "table-danger" : "")">
                                <td class="ps-3 fw-bold text-primary">@item.RUTA</td>
                                <td class="text-muted">@item.REGION</td>
                                <td class="fw-semibold text-dark">@item.SUCURSAL</td>
                                <td>@FormatFecha(item.FECHA_INI_ES)</td>
                                <td>@FormatFecha(item.FECHA_FIN_ES)</td>
                                <td>@FormatFecha(item.FECHA_INI_RE)</td>
                                <td>@FormatFecha(item.FECHA_FIN_RE)</td>
                                <td class="text-center">
                                    @if (sinFechaEst)
                                    {
                                        <span class="badge bg-secondary rounded-pill px-3">No programado</span>
                                    }
                                    else if (sinFechaRe)
                                    {
                                        <span class="badge bg-secondary rounded-pill px-3">No iniciado</span>
                                    }
                                    else if (sinFinReal)
                                    {
                                        <span class="badge rounded-pill px-3"
                                              style="background-color:#FF8C00;">En proceso</span>
                                    }
                                    else if (item.DIAS_ATRASO > 0)
                                    {
                                        <span class="badge bg-danger rounded-pill px-3">
                                            @item.DIAS_ATRASO días
                                        </span>
                                    }
                                    else if (item.DIAS_ATRASO < 0)
                                    {
                                        <span class="badge rounded-pill px-3"
                                              style="background-color:#007BFF;">
                                            @Math.Abs(item.DIAS_ATRASO ?? 0) días adelanto
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success rounded-pill px-3">En tiempo</span>
                                    }
                                </td>
                                <td class="text-secondary small text-truncate" style="max-width:220px;">
                                    @if (!string.IsNullOrWhiteSpace(item.OBSERVACIONES))
                                    {
                                        <span data-bs-toggle="tooltip" title="@item.OBSERVACIONES">
                                            @item.OBSERVACIONES
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a href="@Url.Action("Observacion", "Seguimiento", new { id = item.ID })"
                                       class="btn btn-sm btn-outline-primary rounded-pill px-3 fw-semibold">
                                        <i class="bi bi-pencil me-1"></i>Editar
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .scale-115 { transform: scale(1.15); cursor: pointer; }
</style>

@section Scripts {
<script>
    // ── URL base generada por Razor (funciona en cualquier virtual path) ─────
    const urlExportar              = '@Url.Action("Exportar",               "Seguimiento")';
    const urlIndex                 = '@Url.Action("Index",                  "Seguimiento")';
    const urlSucursalesFiltro      = '@Url.Action("ObtenerSucursalesFiltro","Seguimiento")';

    // ── Tooltips ─────────────────────────────────────────────────────────────
    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el =>
        new bootstrap.Tooltip(el));

    // ── Limpiar filtros ───────────────────────────────────────────────────────
    document.getElementById('btnLimpiar').addEventListener('click', function () {
        window.location.href = urlIndex;
    });

    // ── Exportar — usa URL generada por Razor para evitar problemas de ruta ──
    document.getElementById('btnExportar').addEventListener('click', function () {
        const params = new URLSearchParams();
        const ruta     = document.getElementById('filtroRuta')?.value;
        const region   = document.getElementById('filtroRegion')?.value;
        const sucursal = document.getElementById('filtroSucursal')?.value;
        const mes      = document.getElementById('filtroMes')?.value;
        const anio     = document.getElementById('filtroAnio')?.value;
        const periodo  = document.getElementById('filtroPeriodo')?.value;
        const ocultar  = document.getElementById('ocultarSinFecha')?.checked;

        if (ruta)     params.append('filtroRuta',      ruta);
        if (region)   params.append('filtroRegion',    region);
        if (sucursal) params.append('filtroSucursal',  sucursal);
        if (mes)      params.append('filtroMes',       mes);
        if (anio)     params.append('filtroAnio',      anio);
        if (periodo)  params.append('filtroPeriodo',   periodo);
        if (ocultar)  params.append('ocultarSinFecha', 'true');

        window.location.href = urlExportar + '?' + params.toString();
    });

    // ── Carga dinámica de sucursales al cambiar ruta ─────────────────────────
    document.getElementById('filtroRuta').addEventListener('change', async function () {
        const ruta       = this.value;
        const selSucursal = document.getElementById('filtroSucursal');

        selSucursal.innerHTML = '<option value="">Cargando...</option>';
        if (!ruta) {
            selSucursal.innerHTML = '<option value="">— Todas —</option>';
            return;
        }
        try {
            const res  = await fetch(urlSucursalesFiltro + '?ruta=' + encodeURIComponent(ruta));
            const data = await res.json();
            selSucursal.innerHTML = '<option value="">— Todas —</option>';
            data.forEach(s => {
                const opt       = document.createElement('option');
                opt.value       = s.value;   // CLV_SUC
                opt.textContent = s.text;    // Nombre
                selSucursal.appendChild(opt);
            });
        } catch (e) {
            console.error('Error al cargar sucursales:', e);
            selSucursal.innerHTML = '<option value="">— Todas —</option>';
        }
    });
</script>
}
